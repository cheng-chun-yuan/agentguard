# ────────────────────────────────────────────────────────────────────
# AgentGuard POC — environment configuration
# Copy to .env and fill in your values
# ────────────────────────────────────────────────────────────────────

# Owner EOA private key (the "user" — will be 7702-delegated to Kernel)
# For POC: generate a fresh one. Production: this comes from Privy.
# Generate with: node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
OWNER_PRIVATE_KEY=0x...

# ZeroDev v3 RPC URL — serves both bundler and paymaster
# Get from: https://dashboard.zerodev.app → your Base Sepolia project
ZERODEV_RPC=https://rpc.zerodev.app/api/v3/YOUR_PROJECT_ID/chain/84532

# Base Sepolia public RPC (any will do)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Test recipient — where the session key will try to transfer USDC
TEST_RECIPIENT=0x000000000000000000000000000000000000dEaD

# Base Sepolia testnet USDC (Circle's official test token)
# Already filled in — don't change unless you want to test a different token.
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Server config
PORT=3001

# ZeroDev v3 RPC URL (serves bundler + paymaster)
ZERODEV_RPC=https://rpc.zerodev.app/api/v3/YOUR_PROJECT_ID/chain/84532

# Base Sepolia public RPC
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Where the dev wallet's owner key lives in plaintext (hackathon only).
# In production: per-developer Privy server wallets. For now we use one
# shared "master" EOA when provisioning new Agents — the backend signs
# the initial UserOp that installs the session key validators.
#
# Generate with:
#   bun -e "console.log('0x' + Array.from(crypto.getRandomValues(new Uint8Array(32))).map(b=>b.toString(16).padStart(2,'0')).join(''))"
DEV_OWNER_PRIVATE_KEY=0x...

# Where SQLite lives (relative to backend cwd, or absolute)
DB_PATH=./agentguard.db

# Optional CORS origin for the dashboard (set when dashboard exists)
DASHBOARD_ORIGIN=http://localhost:3000

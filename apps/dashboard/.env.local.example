# ────────────────────────────────────────────────────────────────────
# AgentGuard Dashboard — environment configuration
# Copy to .env.local and fill in your values
# ────────────────────────────────────────────────────────────────────

# Privy app credentials
# Get from: https://dashboard.privy.io (create app → enable Base Sepolia +
# embedded wallets). The app ID is safe to expose publicly.
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id

# Backend API base URL — defaults to local dev backend
NEXT_PUBLIC_BACKEND_URL=http://localhost:3737

# ZeroDev RPC (same one used by the backend)
NEXT_PUBLIC_ZERODEV_RPC=https://rpc.zerodev.app/api/v3/YOUR_PROJECT_ID/chain/84532
